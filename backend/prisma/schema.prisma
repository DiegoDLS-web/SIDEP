generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model ActividadUsuario {
  id         Int      @id @default(autoincrement())
  usuarioId  Int?     @map("usuario_id")
  accion     String
  modulo     String
  referencia String?
  detalle    Json?
  fecha      DateTime @default(now())
  
  usuario    Usuario? @relation(fields: [usuarioId], references: [id])

  @@map("actividades_usuario")
}

model Carro {
  id                             Int      @id @default(autoincrement())
  nomenclatura                   String   @unique
  patente                        String   @unique
  estadoOperativo                Boolean  @default(true) @map("estado_operativo")
  nombre                         String?
  tipo                           String?
  marca                          String?
  anioFabricacion                Int?     @map("anio_fabricacion")
  capacidadAgua                  String?  @map("capacidad_agua")
  imagenUrl                      String?  @map("imagen_url")
  kilometraje                    Int?
  ultimoMantenimiento            DateTime? @map("ultimo_mantenimiento")
  proximoMantenimiento           DateTime? @map("proximo_mantenimiento")
  conductorAsignado              String?  @map("conductor_asignado")
  motor                          String?
  transmision                    String?
  combustible                    String?
  presionBomba                   String?  @map("presion_bomba")
  capacidadTanqueCombustible     String?  @map("capacidad_tanque_combustible")
  descripcionUltimoMantenimiento String?  @map("descripcion_ultimo_mantenimiento")
  proximaRevisionTecnica         DateTime? @map("proxima_revision_tecnica")
  ultimaRevisionBombaAgua        DateTime? @map("ultima_revision_bomba_agua")
  ultimoInspector                String?  @map("ultimo_inspector")
  firmaUltimoInspector           String?  @map("firma_ultimo_inspector")
  fechaUltimaInspeccion          DateTime? @map("fecha_ultima_inspeccion")
  ultimoConductor                String?  @map("ultimo_conductor")
  
  historiales                    CarroRegistroHistorial[]
  checklists                     ChecklistCarro[]
  emergencias                    UnidadEnEmergencia[]

  @@map("carros")
}

model CarroRegistroHistorial {
  id                             Int      @id @default(autoincrement())
  carroId                        Int      @map("carro_id")
  creadoEn                       DateTime @default(now()) @map("creado_en")
  ultimoMantenimiento            DateTime? @map("ultimo_mantenimiento")
  proximoMantenimiento           DateTime? @map("proximo_mantenimiento")
  proximaRevisionTecnica         DateTime? @map("proxima_revision_tecnica")
  ultimaRevisionBombaAgua        DateTime? @map("ultima_revision_bomba_agua")
  descripcionUltimoMantenimiento String?  @map("descripcion_ultimo_mantenimiento")
  ultimoInspector                String?  @map("ultimo_inspector")
  firmaUltimoInspector           String?  @map("firma_ultimo_inspector")
  fechaUltimaInspeccion          DateTime? @map("fecha_ultima_inspeccion")
  ultimoConductor                String?  @map("ultimo_conductor")
  
  carro                          Carro    @relation(fields: [carroId], references: [id], onDelete: Cascade)

  @@index([carroId])
  @@map("carro_registro_historial")
}

model ChecklistCarro {
  id             Int      @id @default(autoincrement())
  carroId        Int      @map("carro_id")
  cuarteleroId   Int      @map("cuartelero_id")
  fecha          DateTime @default(now())
  tipo           String   @default("UNIDAD")
  inspector      String?
  grupoGuardia   String?  @map("grupo_guardia")
  firmaOficial   String?  @map("firma_oficial")
  observaciones  String?
  totalItems     Int?     @map("total_items")
  itemsOk        Int?     @map("items_ok")
  detalle        Json?
  firmaInspector String?  @map("firma_inspector")
  
  carro          Carro    @relation(fields: [carroId], references: [id])
  cuartelero     Usuario  @relation(fields: [cuarteleroId], references: [id])

  @@map("checklists_carro")
}

model ConfiguracionSistema {
  id        Int      @id @default(autoincrement())
  clave     String   @unique
  valor     Json
  updatedAt DateTime @map("updated_at")

  @@map("configuracion_sistema")
}

model LicenciaMedica {
  id                    Int      @id @default(autoincrement())
  usuarioId             Int      @map("usuario_id")
  fechaInicio           DateTime @map("fecha_inicio")
  fechaTermino          DateTime @map("fecha_termino")
  motivo                String
  archivoUrl            String?  @map("archivo_url")
  estado                String   @default("PENDIENTE")
  observacionResolucion String?  @map("observacion_resolucion")
  resueltoPorId         Int?     @map("resuelto_por_id")
  resueltoEn            DateTime? @map("resuelto_en")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @map("updated_at")
  
  resueltoPor           Usuario? @relation("LicenciaMedica_resueltoPorIdToUsuario", fields: [resueltoPorId], references: [id])
  usuario               Usuario  @relation("LicenciaMedica_usuarioIdToUsuario", fields: [usuarioId], references: [id], onDelete: Cascade)

  @@index([estado, fechaInicio, fechaTermino])
  @@index([usuarioId, fechaInicio, fechaTermino])
  @@map("licencias_medicas")
}

model PacienteEmergencia {
  id              Int             @id @default(autoincrement())
  parteId         Int             @map("parte_id")
  nombre          String
  triage          String
  edad            Int?
  rut             String?
  
  parteEmergencia ParteEmergencia @relation(fields: [parteId], references: [id])

  @@map("pacientes_emergencia")
}

model ParteEmergencia {
  id              Int                  @id @default(autoincrement())
  correlativo     String               @unique
  claveEmergencia String               @map("clave_emergencia")
  direccion       String
  fecha           DateTime             @default(now())
  estado          String               @default("PENDIENTE")
  obacId          Int                  @map("obac_id")
  metadata        Json?
  
  pacientes       PacienteEmergencia[]
  obac            Usuario              @relation(fields: [obacId], references: [id])
  unidades        UnidadEnEmergencia[]

  @@index([claveEmergencia, fecha(sort: Desc)])
  @@index([fecha(sort: Desc)])
  @@map("partes_emergencia")
}

model PasswordResetToken {
  id        Int      @id @default(autoincrement())
  usuarioId Int      @map("usuario_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime @default(now()) @map("created_at")
  
  usuario   Usuario  @relation(fields: [usuarioId], references: [id])

  @@map("password_reset_tokens")
}

model RolUsuario {
  id        Int      @id @default(autoincrement())
  nombre    String   @unique
  activo    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @map("updated_at")

  @@map("roles_usuario")
}

model UnidadEnEmergencia {
  id              Int             @id @default(autoincrement())
  parteId         Int             @map("parte_id")
  carroId         Int             @map("carro_id")
  horaSalida      String          @map("hora_salida")
  horaLlegada     String          @map("hora_llegada")
  kmSalida        Int             @map("km_salida")
  kmLlegada       Int             @map("km_llegada")
  hora6_0         String          @default("00:00")
  hora6_3         String          @default("00:00")
  hora6_9         String          @default("00:00")
  hora6_10        String          @default("00:00")
  
  carro           Carro           @relation(fields: [carroId], references: [id])
  parteEmergencia ParteEmergencia @relation(fields: [parteId], references: [id])

  @@map("unidades_en_emergencia")
}

model Usuario {
  id                     Int                  @id @default(autoincrement())
  rut                    String               @unique
  nombre                 String
  rol                    String
  password               String
  email                  String?              @unique
  telefono               String?
  activo                 Boolean              @default(true)
  nombres                String?
  apellidoPaterno        String?              @map("apellido_paterno")
  apellidoMaterno        String?              @map("apellido_materno")
  nacionalidad           String?
  grupoSanguineo         String?              @map("grupo_sanguineo")
  direccion              String?
  region                 String?
  comuna                 String?
  actividad              String?
  fechaNacimiento        DateTime?            @map("fecha_nacimiento")
  fechaIngreso           DateTime?            @map("fecha_ingreso")
  tipoVoluntario         String?              @map("tipo_voluntario")
  cuerpoBombero          String?              @map("cuerpo_bombero")
  compania               String?
  estadoVoluntario       String?              @default("VIGENTE") @map("estado_voluntario")
  cargoOficialidad       String?              @map("cargo_oficialidad")
  observacionesRegistro  String?              @map("observaciones_registro")
  firmaImagen            String?              @map("firma_imagen")
  createdAt              DateTime             @default(now()) @map("created_at")
  updatedAt              DateTime             @map("updated_at")
  requiereCambioPassword Boolean              @default(false) @map("requiere_cambio_password")
  fotoPerfil             String?              @map("foto_perfil")
  autorizadoConducir     Boolean              @default(false) @map("autorizado_conducir")
  claveNomina            String?              @unique @map("clave_nomina")
  
  actividades            ActividadUsuario[]
  checklists             ChecklistCarro[]
  licenciasResueltas     LicenciaMedica[]     @relation("LicenciaMedica_resueltoPorIdToUsuario")
  licenciasPropias       LicenciaMedica[]     @relation("LicenciaMedica_usuarioIdToUsuario")
  partesObac             ParteEmergencia[]
  passwordResetTokens    PasswordResetToken[]

  @@map("usuarios")
}